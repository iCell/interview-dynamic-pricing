# ---------------------------------------------------------------------------
# Single source of truth for runtime configuration.
#
# Consumed by:
#   • docker-compose.yml (via `env_file: .env`) — passed into the container
#   • Rails code via ENV.fetch(...) at runtime; matching defaults live in the
#     Ruby source so the app still boots if .env is missing.
#
# The values below are tuned for the assignment's constraints (10k req/day,
# 5-minute rate validity, single API token). See README.md §"Configuration"
# and §"Design Decisions & Trade-offs" for the rationale behind each knob.
#
# In a real production deployment these would be injected by the orchestrator
# (Kubernetes secrets, AWS Parameter Store, etc.) — committing the file here
# is a convenience for assignment review only.
# ---------------------------------------------------------------------------

# --- Upstream rate-api -----------------------------------------------------
# Inside docker-compose, "rate-api" resolves to the upstream container.
# For local non-Docker runs, replace with http://localhost:8080.
RATE_API_URL=http://rate-api:8080

# Provided fixture token from the assignment.
RATE_API_TOKEN=04aa6f42aa03f220c2ae9a276cd68c62

# TCP/TLS connect timeout (seconds).
RATE_API_OPEN_TIMEOUT=2

# HTTP read timeout (seconds). open + read = 7 s, strictly < lock TTL (10 s).
RATE_API_READ_TIMEOUT=5

# --- Redis (cache + distributed lock) --------------------------------------
# Inside docker-compose, "redis" resolves to the redis container.
# For local non-Docker runs, replace with redis://localhost:6379/0.
REDIS_URL=redis://redis:6379/0

# --- Pricing cache + lock parameters ---------------------------------------
# Rate validity window. 300 s is a hard business constraint.
PRICING_CACHE_TTL_SECONDS=300

# Lock auto-release window. > worst-case upstream call (7 s) by design.
PRICING_LOCK_TTL_SECONDS=10

# Total waiter deadline. Covers typical upstream latencies; past this we
# return 503 rather than tie up a Puma worker.
PRICING_LOCK_WAIT_SECONDS=5

# Waiter polling interval. 100 polls per 5 s — trivial Redis load.
PRICING_LOCK_POLL_MS=50
